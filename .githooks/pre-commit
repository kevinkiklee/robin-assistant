#!/usr/bin/env bash
# Robin pre-commit hook
#
# Two responsibilities:
#   1. Atomic-commit drift warning — flag the case where a staged file also
#      has unstaged modifications. Pattern that bit us during concurrent
#      agent sessions (CLAUDE.md "multi-agent git hygiene"). Hook can't
#      reject `-a`/`-am` directly (index is already widened by the time the
#      hook runs), so we surface a warning + recommend post-commit verify.
#   2. When a file under system/runtime/invariants/ is staged, regenerate the
#      auto-generated runbook section in CLAUDE.md and stage the diff. The CI
#      `lint:runbook` script catches drift if this hook isn't installed.
#
# To activate: git config core.hooksPath .githooks

set -euo pipefail

# Find staged files (added, copied, modified, renamed)
staged=$(git diff --cached --name-only --diff-filter=ACMR)

# Atomic-commit drift warning — runs for ALL commits, not just invariant
# changes. Tests whether any staged file also has unstaged modifications.
unstaged_modified=$(git diff --name-only --diff-filter=M)

if [[ -n "$staged" && -n "$unstaged_modified" ]]; then
  drift=$(comm -12 <(echo "$staged" | sort -u) <(echo "$unstaged_modified" | sort -u))
  if [[ -n "$drift" ]]; then
    echo "[robin precommit] WARN: staged files have unstaged modifications:" >&2
    echo "$drift" | sed 's/^/  /' >&2
    echo "[robin precommit] continuing — verify with: git show HEAD --stat" >&2
  fi
fi

# Only run runbook regen if invariants/* changed
if ! echo "$staged" | grep -q '^system/runtime/invariants/'; then
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

echo "[robin precommit] invariants changed; regenerating runbook..."
if ! node system/bin/robin doctor --emit-runbook --write >/dev/null; then
  echo "[robin precommit] runbook generation failed" >&2
  exit 1
fi

# Stage the resulting CLAUDE.md diff (if any)
if ! git diff --quiet CLAUDE.md; then
  git add CLAUDE.md
  echo "[robin precommit] staged updated CLAUDE.md"
fi

exit 0
