# Pin pnpm-spawned commands to the same Node version the user's shell sees
# (nvm-managed 24.x). Without this, `pnpm exec node` picks up Homebrew's
# Node 25 from /opt/homebrew/bin/node, while `node` directly resolves via
# nvm to 24.x — producing NODE_MODULE_VERSION mismatches when better-sqlite3
# (and any other native addon) is built for one and loaded under the other.
use-node-version=24.14.1
