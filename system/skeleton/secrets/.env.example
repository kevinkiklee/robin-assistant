# Robin secrets — copy to .env and fill in real values.
# .env is gitignored. Never commit real values.

# Lunch Money — personal finance aggregator (https://lunchmoney.app)
# Get from: https://my.lunchmoney.app/developers
LUNCH_MONEY_API_KEY=

# Discord bot (personal-only; see user-data/scripts/discord-bot.js)
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_GUILD_ID=
DISCORD_BOT_CLAUDE_PATH=
DISCORD_BOT_TIMEOUT_MS=600000
DISCORD_BOT_MAX_TURNS=30
DISCORD_BOT_MAX_CONCURRENT_RUNS=4
