# Robin secrets — copy to .env and fill in real values.
# .env is gitignored. Never commit real values.
#
# Detailed setup walkthroughs (provider console steps, gotchas) live in
# system/integrations/ — start there before filling in any keys below.

# Lunch Money — personal finance aggregator (https://lunchmoney.app)
# Get from: https://my.lunchmoney.app/developers
LUNCH_MONEY_API_KEY=

# Google OAuth — Calendar + Gmail sync (shared client)
# Create OAuth 2.0 Client ID, type "Desktop", at:
#   https://console.cloud.google.com/apis/credentials
# Enable APIs in the same project: Google Calendar API, Gmail API.
# Then run: node user-data/runtime/scripts/auth-google.js
# (auth-google.js writes GOOGLE_OAUTH_REFRESH_TOKEN automatically)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# GitHub — fine-grained personal access token
# Generate at: https://github.com/settings/tokens?type=beta
# Suggested scopes: read:user, repo (or public_repo), notifications.
# Note: fine-grained PATs cannot access /notifications — sync-github skips
# gracefully. For notification sync, use a classic PAT with `notifications` scope.
GITHUB_PAT=

# Spotify OAuth — recently played, top tracks, playlists
# Create app at: https://developer.spotify.com/dashboard
# Add redirect URI: http://127.0.0.1:8765/oauth-callback
# (Spotify requires loopback IP, not "localhost")
# Then run: node user-data/runtime/scripts/auth-spotify.js
# (auth-spotify.js writes SPOTIFY_REFRESH_TOKEN automatically)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Discord bot (personal-only; see user-data/runtime/scripts/discord-bot.js)
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_GUILD_ID=
DISCORD_BOT_CLAUDE_PATH=
DISCORD_BOT_TIMEOUT_MS=600000
DISCORD_BOT_MAX_TURNS=100
DISCORD_BOT_MAX_CONCURRENT_RUNS=4
