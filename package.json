{
  "name": "robin-assistant",
  "version": "5.0.0",
  "description": "A self-improving personal assistant for Claude Code",
  "type": "module",
  "bin": {
    "robin": "bin/robin.js"
  },
  "scripts": {
    "test": "node --test 'system/tests/**/*.test.js'",
    "backup": "node system/scripts/cli/backup.js",
    "restore": "node system/scripts/cli/restore.js",
    "reset": "node system/scripts/cli/reset.js",
    "regenerate-memory-index": "node system/scripts/memory/regenerate-index.js",
    "sync-lunch-money": "node user-data/runtime/scripts/sync-lunch-money.js",
    "analyze-finances": "node system/scripts/diagnostics/analyze-finances.js",
    "regenerate-links": "node system/scripts/memory/regenerate-links.js",
    "measure-tokens": "node system/scripts/diagnostics/measure-tokens.js",
    "lint-memory": "node system/scripts/memory/lint.js",
    "densify-wiki": "node system/scripts/memory/densify-wiki.js",
    "golden-session": "node system/scripts/diagnostics/golden-session.js",
    "prune-preview": "node system/scripts/memory/prune-preview.js",
    "prune-execute": "node system/scripts/memory/prune-execute.js",
    "migrate-auto-memory": "node system/scripts/capture/auto-memory.js",
    "jobs": "node bin/robin.js jobs",
    "jobs:sync": "node bin/robin.js jobs sync",
    "jobs:list": "node bin/robin.js jobs list",
    "discord:auth": "node user-data/runtime/scripts/auth-discord.js",
    "discord:install": "node user-data/runtime/scripts/discord-bot-install.js",
    "discord:uninstall": "node user-data/runtime/scripts/discord-bot-install.js --uninstall",
    "discord:status": "node user-data/runtime/scripts/discord-bot-status.js",
    "discord:health": "node user-data/runtime/scripts/discord-bot-health.js",
    "postinstall": "node system/scripts/cli/setup.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "assistant",
    "personal-assistant",
    "claude-code",
    "discord"
  ],
  "license": "MIT",
  "author": "Kevin K Lee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinkiklee/robin-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/kevinkiklee/robin-assistant/issues"
  },
  "homepage": "https://github.com/kevinkiklee/robin-assistant#readme",
  "files": [
    "bin",
    "system",
    "CLAUDE.md",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "discord.js": "^14.26.3",
    "dotenv": "^16.6.1"
  }
}
