{
  "name": "robin-assistant",
  "version": "6.0.0-alpha.15",
  "description": "SurrealDB-first personal AI assistant (v2 rebuild)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "robin": "bin/robin"
  },
  "scripts": {
    "setup": "node bin/robin install",
    "test": "node --test --test-force-exit 'tests/**/*.test.js'",
    "test:unit": "node --test --test-force-exit 'tests/unit/**/*.test.js'",
    "test:integration": "node --test --test-force-exit 'tests/integration/**/*.test.js'",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@surrealdb/node": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.4",
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  },
  "license": "MIT",
  "author": "Kevin K Lee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinkiklee/robin-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/kevinkiklee/robin-assistant/issues"
  },
  "homepage": "https://github.com/kevinkiklee/robin-assistant#readme",
  "keywords": [
    "ai",
    "ai-assistant",
    "memory",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "gemini-cli",
    "surrealdb",
    "personal-ai"
  ]
}
