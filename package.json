{
  "name": "robin-assistant",
  "version": "6.0.0-alpha.12",
  "description": "SurrealDB-first personal AI assistant (v2 rebuild)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "robin": "bin/robin"
  },
  "scripts": {
    "setup": "node bin/robin install",
    "test": "node --test --test-force-exit 'tests/**/*.test.js'",
    "test:unit": "node --test --test-force-exit 'tests/unit/**/*.test.js'",
    "test:integration": "node --test --test-force-exit 'tests/integration/**/*.test.js'",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@surrealdb/node": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "discord.js": "^14.26.4",
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  },
  "license": "MIT",
  "author": "Kevin K Lee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinkiklee/robin-assistant.git"
  }
}
