{
  "name": "robin-assistant",
  "version": "3.4.0",
  "description": "A self-improving personal assistant — portable across AI coding tools",
  "type": "module",
  "bin": {
    "robin": "bin/robin.js"
  },
  "scripts": {
    "test": "find system/tests -type f -name '*.test.js' -print0 | xargs -0 node --test",
    "backup": "node system/scripts/cli/backup.js",
    "restore": "node system/scripts/cli/restore.js",
    "reset": "node system/scripts/cli/reset.js",
    "regenerate-pointers": "node system/scripts/memory/regenerate-pointers.js",
    "regenerate-memory-index": "node system/scripts/memory/regenerate-index.js",
    "sync-lunch-money": "node user-data/scripts/sync-lunch-money.js",
    "analyze-finances": "node system/scripts/analyze-finances.js",
    "regenerate-links": "node system/scripts/memory/regenerate-links.js",
    "measure-tokens": "node system/scripts/measure-tokens.js",
    "lint-memory": "node system/scripts/memory/lint.js",
    "golden-session": "node system/scripts/golden-session.js",
    "prune-preview": "node system/scripts/memory/prune-preview.js",
    "prune-execute": "node system/scripts/memory/prune-execute.js",
    "migrate-auto-memory": "node system/scripts/migrate-auto-memory.js",
    "jobs": "node bin/robin.js jobs",
    "jobs:sync": "node bin/robin.js jobs sync",
    "jobs:list": "node bin/robin.js jobs list",
    "discord:auth": "node user-data/scripts/auth-discord.js",
    "discord:install": "node user-data/scripts/discord-bot-install.js",
    "discord:uninstall": "node user-data/scripts/discord-bot-install.js --uninstall",
    "discord:status": "node user-data/scripts/discord-bot-status.js",
    "discord:health": "node user-data/scripts/discord-bot-health.js",
    "postinstall": "node system/scripts/cli/setup.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "assistant",
    "personal-assistant",
    "claude-code",
    "cursor",
    "gemini-cli",
    "codex",
    "antigravity",
    "discord"
  ],
  "license": "MIT",
  "author": "Kevin K Lee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinkiklee/robin-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/kevinkiklee/robin-assistant/issues"
  },
  "homepage": "https://github.com/kevinkiklee/robin-assistant#readme",
  "files": [
    "bin",
    "system",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "discord.js": "^14.26.3",
    "dotenv": "^16.6.1"
  }
}
