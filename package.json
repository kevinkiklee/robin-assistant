{
  "name": "robin-assistant",
  "version": "6.0.0-alpha.17",
  "description": "SurrealDB-first personal AI assistant",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "robin": "system/bin/robin"
  },
  "files": [
    "AGENTS.md",
    "CHANGELOG.md",
    "docs/architecture.md",
    "docs/development.md",
    "docs/faculties.md",
    "docs/install.md",
    "docs/troubleshooting.md",
    "system/bin/",
    "system/cognition/",
    "system/config/",
    "system/data/",
    "system/io/",
    "system/runtime/cli/",
    "system/runtime/daemon/",
    "system/runtime/hosts/",
    "system/runtime/install/"
  ],
  "scripts": {
    "postinstall": "node system/runtime/install/postinstall.js",
    "setup": "node system/bin/robin install",
    "test": "node --test --test-force-exit --test-timeout=20000 'system/tests/**/*.test.js'",
    "test:unit": "node --test --test-force-exit --test-timeout=20000 'system/tests/unit/**/*.test.js'",
    "test:integration": "node --test --test-force-exit --test-timeout=20000 'system/tests/integration/**/*.test.js'",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@surrealdb/node": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.4",
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  },
  "license": "MIT",
  "author": "Kevin K Lee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinkiklee/robin-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/kevinkiklee/robin-assistant/issues"
  },
  "homepage": "https://github.com/kevinkiklee/robin-assistant#readme",
  "keywords": [
    "ai",
    "ai-assistant",
    "memory",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "gemini-cli",
    "surrealdb",
    "personal-ai"
  ]
}
