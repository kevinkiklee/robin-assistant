{
  "name": "robin-assistant",
  "version": "3.3.0",
  "description": "A self-improving personal assistant — portable across AI coding tools",
  "type": "module",
  "bin": {
    "robin": "bin/robin.js"
  },
  "scripts": {
    "test": "find system/tests -type f -name '*.test.js' -print0 | xargs -0 node --test",
    "backup": "node system/scripts/backup.js",
    "restore": "node system/scripts/restore.js",
    "reset": "node system/scripts/reset.js",
    "regenerate-pointers": "node system/scripts/regenerate-pointers.js",
    "regenerate-memory-index": "node system/scripts/regenerate-memory-index.js",
    "split-monoliths": "node system/scripts/split-monoliths.js",
    "sync-lunch-money": "node user-data/scripts/sync-lunch-money.js",
    "analyze-finances": "node system/scripts/analyze-finances.js",
    "regenerate-links": "node system/scripts/regenerate-links.js",
    "measure-tokens": "node system/scripts/measure-tokens.js",
    "lint-memory": "node system/scripts/lint-memory.js",
    "golden-session": "node system/scripts/golden-session.js",
    "jobs": "node bin/robin.js jobs",
    "jobs:sync": "node bin/robin.js jobs sync",
    "jobs:list": "node bin/robin.js jobs list",
    "postinstall": "node system/scripts/setup.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "assistant",
    "personal-assistant",
    "claude-code",
    "cursor",
    "gemini-cli",
    "codex",
    "antigravity"
  ],
  "license": "MIT",
  "author": "Kevin K Lee",
  "repository": {
    "type": "git",
    "url": ""
  }
}
