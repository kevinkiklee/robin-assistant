{
  "name": "robin-assistant",
  "version": "5.2.0",
  "description": "A self-improving personal assistant for Claude Code",
  "type": "module",
  "bin": {
    "robin": "bin/robin.js"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test 'system/tests/{capture,cli,diagnostics,discord,hooks,jobs,lib,memory,migrate,security,sync,watches,wiki-graph}/**/*.test.js'",
    "test:e2e": "node --test 'system/tests/e2e/{hooks,memory,jobs,pipeline}/**/*.test.js'",
    "test:install": "node --test --test-timeout=120000 'system/tests/e2e/install/**/*.test.js'",
    "postinstall": "node system/scripts/cli/setup.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "assistant",
    "personal-assistant",
    "claude-code",
    "discord"
  ],
  "license": "MIT",
  "author": "Kevin K Lee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinkiklee/robin-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/kevinkiklee/robin-assistant/issues"
  },
  "homepage": "https://github.com/kevinkiklee/robin-assistant#readme",
  "files": [
    "bin",
    "system",
    "CHANGELOG.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "discord.js": "^14.26.3",
    "dotenv": "^16.6.1"
  }
}
